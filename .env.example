# Andeck — copy thành .env rồi điền giá trị thật
# Local: copy .env.example .env
# Render: thêm biến trong Dashboard → Environment

# MongoDB Atlas — database riêng tên "andeck" (không dùng chung Hanzi Learn)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/andeck

# JWT — chuỗi bí mật mới, khác Hanzi Learn
JWT_SECRET=your_random_secret_at_least_32_chars

# Port (Render tự inject PORT; local mặc định 3000)
PORT=3000
